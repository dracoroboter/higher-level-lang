// Benchmark L1 — p1 "null train"
// Equivalent to BenchmarkL1.java without antipatterns
//
// Antipatterns eliminated:
// - NPE: address is Option, handled with match
// - Stringly-typed: Email, Money, ZipCode sono tipi nominali
// - Demeter: deep access wrapped in dedicated functions

import hll.validation as validate

type Email = String where validate.email()
type ZipCode = String where validate.matches("^[0-9]{5}$")
type MoneyAmount = String where validate.matches("^[0-9]+\\.[0-9]{2}$")
type Country = String where validate.max_length(2)

struct City {
    name: String
    zip: ZipCode
}

struct Address {
    street: String
    city: City
    country: Country
}

struct Customer {
    name: String
    email: Email
    address: Option<Address>
}

struct Money {
    amount: MoneyAmount
}

struct Order {
    id: Int
    customer: Customer
    total: Money
    status: String
}

// Demeter-safe functions (encapsulated navigation)
fn customerCity(order: Order) -> String {
    match order.customer.address {
        Some(addr) => addr.city.name
        None => "Unknown"
    }
}

fn customerZip(order: Order) -> String {
    match order.customer.address {
        Some(addr) => addr.city.zip
        None => "Unknown"
    }
}

fn print_order(order: Order) {
    printLn("Order #" + order.id)
    printLn("Customer: " + order.customer.name)
    printLn("Email: " + order.customer.email)
    printLn("Total: " + order.total.amount)
    printLn("City: " + customerCity(order))
    printLn("Zip: " + customerZip(order))
}

fn main(args: List<String>) {
    let name = args.get(0)
    let email = Email(args.get(1))
    let amount = MoneyAmount(args.get(2))
    let hasAddress = args.get(3) == "true"

    let address: Option<Address> = match hasAddress {
        true => Some(Address("Via Roma 1", City("Milano", ZipCode("20100")), Country("IT")))
        false => None
    }

    let customer = Customer(name, email, address)
    let order = Order(1, customer, Money(amount), "pending")
    print_order(order)
}
