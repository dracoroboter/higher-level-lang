// MUST BE REJECTED: send after disconnect

state Connection {
    Disconnected {
        function connect() -> Connected
    }
    Connected {
        function send() -> Connected
        function disconnect() -> Closed
    }
    Closed { }
}

function main() {
    let conn = Connection.new()
    conn.connect()
    conn.disconnect()
    conn.send()  // ERROR: send not available in state Closed
}
