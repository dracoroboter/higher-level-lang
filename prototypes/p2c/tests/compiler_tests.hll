// Compiler test suite for p2a "result chain"
// Run with: hll compiler_tests.hll --test

import hll.validation as validate

type Email = String where validate.email()
type URL = String where validate.url()
type Query = String
type OrderId = Int
type CityName = String

struct Address {
    CityName city
}

struct Customer {
    String name,
    Email email,
    Option<Address> address
}

struct InvalidEmail { String input }

function send(Email to, URL link) {
    printLn(to)
}

function execute(Query sql) {
    printLn(sql)
}

function parseEmail(String input) -> Result<Email, InvalidEmail> {
    Ok(Email(input))
}

// === NULL SAFETY ===

test "null does not exist" {
    expect_error {
        let Customer c = null
    }
}

// === OPTION HANDLING ===

test "cannot access field on Option without match" {
    expect_error {
        let Customer c = Customer("Alice", Email("a@b.com"), None)
        c.address.city
    }
}

// === NOMINAL TYPES ===

test "nominal types are not interchangeable" {
    expect_error {
        let Email e = Email("a@b.com")
        let URL u = URL("https://x.com")
        send(u, e)
    }
}

test "raw String rejected where Email expected" {
    expect_error {
        send("not-an-email", URL("https://x.com"))
    }
}

test "raw String rejected where URL expected" {
    expect_error {
        send(Email("a@b.com"), "not-a-url")
    }
}

test "SQL injection prevented by nominal types" {
    expect_error {
        let input = "Robert'; DROP TABLE users;--"
        execute(input)
    }
}

// TODO: "OrderId is not Int" — type checker does not yet verify nominal types in let assignments
// Only verified in function call parameters

// === RESULT HANDLING ===



// === DEMETER (warnings, not errors — these test that code compiles but warns) ===

// Note: Demeter violations produce warnings, not errors.
// These are valid programs that should compile.

// === IMPERATIVE CORRECTNESS ===

test "function with return type must return" {
    assert true
}

test "valid program compiles" {
    assert true
}

// === FAILS (p2c specific) ===

struct ParseError { String msg }

function riskyOperation(String input) -> String fails ParseError {
    fail ParseError(input)
}

test "fails must be handled by caller" {
    expect_error {
        let result = riskyOperation("bad")
    }
}
